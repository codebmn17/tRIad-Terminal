# tRIad Terminal Configuration

# Dataset System Configuration
# Enable automatic download of initial datasets on startup
AUTO_DOWNLOAD_DATASETS=1

# Enable embeddings and vector search capabilities
ENABLE_EMBEDDINGS=1

# Embedding system configuration
EMBEDDING_BACKEND=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MAX_EMBED_CHUNK_TOKENS=512

# Initial datasets to download (comma-separated list)
INITIAL_DATASETS=codesearchnet_small,wiki_history_events,sec_filings_sample

# Performance and debugging
TRIAD_PERF=0
DEBUG=0